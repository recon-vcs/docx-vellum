{
  "name": "docx-renderer",
  "version": "0.1.1",
  "description": "Synchronous docx to HTML rendering library for the browser. Fork of docx-preview-sync, evolved for the Recon project.",
  "license": "Apache-2.0",
  "keywords": [
    "word",
    "docx",
    "html",
    "renderer",
    "preview"
  ],
  "author": {
    "name": "stasshe"
  },
  "maintainers": [
    "stasshe"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/recon-vcs/docx-renderer.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/docx-renderer.cjs",
  "module": "./dist/docx-renderer.mjs",
  "types": "./dist/docx-renderer.d.ts",
  "browser": "./dist/docx-renderer.umd.js",
  "exports": {
    ".": {
      "types": "./dist/docx-renderer.d.ts",
      "import": "./dist/docx-renderer.mjs",
      "require": "./dist/docx-renderer.cjs"
    }
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "rollup --config rollup.config.mjs",
    "watch": "rollup --config rollup.config.mjs --watch",
    "test": "vitest run",
    "test:line-count": "vitest run tests/unit/line-count.spec.ts",
    "test:watch": "vitest",
    "test:browser": "playwright test"
  },
  "dependencies": {
    "@types/node": "^25.9.3",
    "jszip": "^3.10.1",
    "konva": "^9.3.22",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/lodash-es": "^4.17.12",
    "jsdom": "^26.1.0",
    "lodash": "^4.18.1",
    "rollup": "^4.62.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-node-externals": "^6.1.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^3.2.6"
  }
}
