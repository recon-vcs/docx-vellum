{
  "name": "docx-vellum",
  "version": "0.1.0",
  "description": "Synchronous docx to HTML rendering library for the browser. Fork of docx-preview-sync, evolved for the Recon project.",
  "license": "Apache-2.0",
  "keywords": [
    "word",
    "docx",
    "html",
    "renderer",
    "preview"
  ],
  "author": {
    "name": "recon-vcs"
  },
  "maintainers": [
    "recon-vcs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/recon-vcs/docx-vellum.git"
  },
  "type": "module",
  "main": "./dist/docx-vellum.cjs",
  "module": "./dist/docx-vellum.mjs",
  "types": "./dist/docx-vellum.d.ts",
  "browser": "./dist/docx-vellum.umd.js",
  "exports": {
    ".": {
      "types": "./dist/docx-vellum.d.ts",
      "import": "./dist/docx-vellum.mjs",
      "require": "./dist/docx-vellum.cjs"
    }
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "rollup --config rollup.config.mjs",
    "watch": "rollup --config rollup.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "playwright test"
  },
  "dependencies": {
    "@types/node": "^25.9.3",
    "jszip": "^3.10.1",
    "konva": "^9.3.22",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/lodash-es": "^4.17.12",
    "jsdom": "^26.1.0",
    "lodash": "^4.18.1",
    "rollup": "^4.62.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-node-externals": "^6.1.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^3.2.6"
  }
}
